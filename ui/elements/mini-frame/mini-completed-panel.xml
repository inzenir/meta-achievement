<Ui xmlns="http://www.blizzard.com/wow/ui/">
    <!-- Compact completed state: shown in mini journal when top achievement of category is completed. -->
    <Frame name="MetaAchievementMiniCompletedPanelTemplate" virtual="true">
        <Size x="280" y="1"/>
        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentAchiIcon">
                    <Size x="32" y="32"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT" x="8" y="-8"/>
                    </Anchors>
                </Texture>
                <FontString name="$parentMessage" inherits="GameFontNormal" justifyH="LEFT" wordWrap="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parentAchiIcon" relativePoint="TOPRIGHT" x="8" y="0"/>
                        <Anchor point="RIGHT" relativeTo="$parent" relativePoint="RIGHT" x="-8" y="0"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentCompletedDate" inherits="GameFontNormalSmall" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parentMessage" relativePoint="BOTTOMLEFT" x="0" y="-4"/>
                        <Anchor point="RIGHT" relativeTo="$parent" relativePoint="RIGHT" x="-8"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="$parentMountPanel" inherits="MetaAchievementMountRewardPanelTemplate">
                <Size x="264" y="100"/>
                <Anchors>
                    <Anchor point="TOP" relativeTo="$parentCompletedDate" relativePoint="BOTTOM" x="0" y="-12"/>
                    <Anchor point="LEFT" relativeTo="$parent" relativePoint="LEFT" x="8" y="0"/>
                    <Anchor point="RIGHT" relativeTo="$parent" relativePoint="RIGHT" x="-8" y="0"/>
                </Anchors>
            </Frame>
        </Frames>
    </Frame>
</Ui>
