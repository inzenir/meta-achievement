<Ui xmlns="http://www.blizzard.com/wow/ui/">
    <!-- Empty state template: shown when journal list has no items (e.g. all completed + hide completed). -->
    <Frame name="MetaAchievementJournalEmptyStateTemplate" virtual="true" inherits="InsetFrameTemplate3">
        <Layers>
            <Layer level="ARTWORK">
                <!-- Achievement icon at top (replaces checkmark) -->
                <Texture name="$parentAchiIcon" setAllPoints="false">
                    <Size x="64" y="64"/>
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parent" relativePoint="TOP" x="0" y="-80"/>
                        <Anchor point="LEFT" relativeTo="$parent" relativePoint="CENTER" x="-32"/>
                    </Anchors>
                </Texture>
                <!-- All lines centered: vertical = TOP to previous BOTTOM; horizontal = LEFT/RIGHT relative to parent CENTER -->
                <FontString name="$parentMessage" inherits="GameFontNormalLarge" text="All achievements in this list are completed.">
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parentAchiIcon" relativePoint="BOTTOM" x="0" y="-16"/>
                        <Anchor point="LEFT" relativeTo="$parent" relativePoint="CENTER" x="-250"/>
                        <Anchor point="RIGHT" relativeTo="$parent" relativePoint="CENTER" x="250"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentAchiName" inherits="GameFontNormalLarge" text="">
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parentMessage" relativePoint="BOTTOM" x="0" y="-24"/>
                        <Anchor point="LEFT" relativeTo="$parent" relativePoint="CENTER" x="-250"/>
                        <Anchor point="RIGHT" relativeTo="$parent" relativePoint="CENTER" x="250"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentCompletedDate" inherits="GameFontNormal" text="">
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parentAchiName" relativePoint="BOTTOM" x="0" y="-8"/>
                        <Anchor point="LEFT" relativeTo="$parent" relativePoint="CENTER" x="-250"/>
                        <Anchor point="RIGHT" relativeTo="$parent" relativePoint="CENTER" x="250"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>
</Ui>
